{
  "type": "module",
  "private": true,
  "scripts": {
    "build": "dotenv -e ./.env.production.local -v NODE_ENV=production -- nuxt build",
    "dev": "dotenv -e ./.env.development.local -v NODE_ENV=development -- nuxt dev",
    "generate": "dotenv -e ./.env.production.local -v NODE_ENV=production -- nuxt generate",
    "knip:deps": "knip --dependencies",
    "knip:exports": "knip --exports",
    "lint": "eslint --max-warnings 0 && stylelint './app/**/*.{css,scss,vue}' -i ./.gitignore --mw 0",
    "lint:fix": "eslint --fix --max-warnings 0 && stylelint './app/**/*.{css,scss,vue}' -i ./.gitignore --fix --mw 0",
    "postinstall": "nuxt prepare",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@kikiutils/nuxt": "^10.3.2",
    "@kikiutils/shared": "^14.1.2",
    "@nuxtjs/robots": "^5.7.1",
    "@vueuse/nuxt": "^14.2.1",
    "nuxt": "^4.3.1",
    "nuxt-security": "^2.5.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "@kikiutils/eslint-config": "^7.0.1",
    "@kikiutils/eslint-plugin-tailwindcss": "^3.19.0",
    "@kikiutils/eslint-plugin-vue": "^10.2.2",
    "@kikiutils/stylelint-config": "^0.4.1",
    "@unocss/nuxt": "^66.6.6",
    "dotenv-cli": "^11.0.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "knip": "^5.86.0",
    "nuxt-vite-plugin-webfont-dl": "^0.1.4",
    "unocss": "^66.6.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ],
    "overrides": {
      "tailwindcss": "^3.4.18"
    }
  }
}
