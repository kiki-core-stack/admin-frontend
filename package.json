{
  "type": "module",
  "private": true,
  "scripts": {
    "build": "dotenv -e ./.env.production.local -v NODE_ENV=production -- nuxt build",
    "dev": "dotenv -e ./.env.development.local -v NODE_ENV=development -- nuxt dev",
    "generate": "dotenv -e ./.env.production.local -v NODE_ENV=production -- nuxt generate",
    "knip:deps": "knip --dependencies",
    "knip:exports": "knip --exports",
    "lint": "eslint --max-warnings 0 && stylelint './app/**/*.{css,scss,vue}' -i ./.gitignore --mw 0",
    "lint:fix": "eslint --fix --max-warnings 0 && stylelint './app/**/*.{css,scss,vue}' -i ./.gitignore --fix --mw 0",
    "postinstall": "nuxt prepare",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@kikiutils/nuxt": "^11.0.0",
    "@kikiutils/shared": "^15.0.2",
    "@nuxtjs/robots": "^6.0.8",
    "@vueuse/nuxt": "^14.2.1",
    "nuxt": "^4.4.2",
    "nuxt-security": "^2.5.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@eslint/css": "^1.1.0",
    "@html-eslint/parser": "^0.59.0",
    "@kikiutils/eslint-config": "^9.0.1",
    "@kikiutils/stylelint-config": "^0.4.1",
    "@unocss/nuxt": "^66.6.8",
    "dotenv-cli": "^11.0.0",
    "eslint-plugin-better-tailwindcss": "^4.4.1",
    "eslint-plugin-format": "^2.0.1",
    "knip": "^6.6.2",
    "tailwind-csstree": "^0.3.1",
    "tailwindcss": "^4.2.4",
    "unocss": "^66.6.8",
    "unplugin-fonts": "^2.0.0",
    "vue-eslint-parser": "^10.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ],
    "overrides": {
      "unimport": "6.0.2"
    }
  }
}
