{
  "type": "module",
  "private": true,
  "scripts": {
    "build": "dotenv -e ./.env.production.local -v NODE_ENV=production -- nuxt build",
    "dev": "dotenv -e ./.env.development.local -v NODE_ENV=development -- pnpm run dev:internal",
    "dev:internal": "node generate-permission-files.ts && nuxt dev",
    "generate": "dotenv -e ./.env.production.local -v NODE_ENV=production -- nuxt generate",
    "knip:deps": "knip --dependencies",
    "knip:exports": "knip --exports",
    "lint": "eslint --max-warnings 0 && stylelint './app/**/*.{css,scss,vue}' -i ./.gitignore --mw 0",
    "lint:fix": "eslint --fix --max-warnings 0 && stylelint './app/**/*.{css,scss,vue}' -i ./.gitignore --fix --mw 0",
    "postinstall": "nuxt prepare",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@element-plus/nuxt": "^1.1.5",
    "@kiki-core-stack/pack": "^0.94.4",
    "@kikiutils/micromatch": "^4.0.9",
    "@kikiutils/nuxt": "^11.0.0",
    "@kikiutils/shared": "^15.0.2",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/robots": "^6.0.8",
    "@sylke/email-validation": "^1.0.0",
    "@vueuse/integrations": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "axios": "^1.15.2",
    "date-fns": "^4.1.0",
    "element-plus": "^2.13.7",
    "es-toolkit": "^1.46.1",
    "html5-qrcode": "^2.3.8",
    "nanoid": "^5.1.11",
    "nuxt": "^4.4.4",
    "nuxt-security": "^2.5.1",
    "qrcode": "^1.5.4",
    "query-string": "^9.3.1",
    "sweetalert2": "^11.26.24",
    "ua-parser-js": "^2.0.9",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@eslint/css": "^1.2.0",
    "@html-eslint/parser": "^0.60.0",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@iconify-json/line-md": "^1.2.16",
    "@iconify-json/mdi": "^1.2.3",
    "@kikiutils/eslint-config": "^9.1.0",
    "@kikiutils/eslint-plugin-vue": "^10.9.0",
    "@kikiutils/mongoose": "^7.0.1",
    "@kikiutils/stylelint-config": "^0.4.1",
    "@nuxt/icon": "^2.2.1",
    "@nuxtjs/i18n": "^10.3.0",
    "@types/micromatch": "^4.0.10",
    "@types/qrcode": "^1.5.6",
    "@unocss/nuxt": "^66.6.8",
    "dotenv-cli": "^11.0.0",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-format": "^2.0.1",
    "knip": "^6.9.0",
    "tailwind-csstree": "^0.3.1",
    "tailwindcss": "^4.2.4",
    "type-fest": "^5.6.0",
    "unocss": "^66.6.8",
    "unplugin-fonts": "^2.0.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-i18n": "^11.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ],
    "overrides": {
      "unimport": "6.0.2"
    }
  }
}
